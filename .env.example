APP_NAME=app-name
NODE_ENV=development
APP_KEY=base64:RfdrOln61jeFdJcpIGQK+6l8HIKcadDhlkFeR1aNn
# App URL
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

APP_COOKIE_KEY="euadSUDE&jsdwag^LL$*"

#--DATABASE CONFIGURATION
# Options: "local" or "supabase"
DB_PROVIDER=local

# LOCAL DATABASE SETTINGS (for development)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=db_development
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# SUPABASE DATABASE SETTINGS (for production/staging)
# Get these from: Supabase Dashboard > Project Settings > Database
# For serverless (Vercel, AWS Lambda): use Transaction mode (port 6543)
# For server (VPS, Docker, long-lived connections): use Session mode (port 5432)
SUPABASE_DB_URL=""
# Example Transaction Pooler: postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Example Direct Connection: postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

#--STORAGE CONFIGURATION
# Options: "local", "s3", "supabase"
STORAGE_DRIVER=local

# LOCAL STORAGE SETTINGS (for development)
# Files will be stored in public/uploads/ and served at APP_URL/uploads/
# No additional config needed for local driver

# AWS S3 SETTINGS (for production with S3)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=your-bucket-name
# Optional: custom CDN domain (without https://)
AWS_S3_CUSTOM_DOMAIN=

# SUPABASE STORAGE SETTINGS (for production with Supabase)
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=uploads

#--EMAIL SMTP (Gmail Configuration)
# For Gmail, choose one of these configurations:
#
# Option 1 (Recommended): Port 587 with TLS
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
#
# Option 2: Port 465 with SSL
# MAIL_PORT=465
# MAIL_ENCRYPTION=ssl
#
# Steps to get Gmail App Password:
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password below (remove spaces)

MAIL_MAILER=smtp
MAIL_HOST=smtp.email.com
MAIL_PORT=465
MAIL_USERNAME=noreply@email.com
MAIL_PASSWORD=password
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@email.com"
MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth (get from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

XENDIT_SECRET_KEY=your-xendit-secret-key
XENDIT_WEBHOOK_TOKEN=